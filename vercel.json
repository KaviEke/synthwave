{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "server.js"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": { "service": "backend" }
        },
        {
            "source": "/assets/(.*)",
            "destination": { "service": "frontend" }
        },
        {
            "source": "/images/(.*)",
            "destination": { "service": "frontend" }
        },
        {
            "source": "/favicon.svg",
            "destination": { "service": "frontend" }
        },
        {
            "source": "/icons.svg",
            "destination": { "service": "frontend" }
        },
        {
            "source": "/(.*)",
            "destination": { "service": "frontend", "path": "/index.html" }
        }
    ]
}
